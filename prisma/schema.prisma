generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Categoria {
  id         Int          @id @default(autoincrement())
  nome       String       @unique
  tipo       String
  cor        String       @default("#6366f1")
  icone      String       @default("tag")
  transacoes Transacao[]
  orcamentos Orcamento[]
  criadoEm   DateTime     @default(now())
}

model Conta {
  id                     Int                     @id @default(autoincrement())
  nome                   String                  @unique
  tipo                   String                  @default("corrente")
  cor                    String                  @default("#3b82f6")
  saldoInicial           Float                   @default(0)
  ativo                  Boolean                 @default(true)
  transacoes             Transacao[]
  transacoesInvestimento TransacaoInvestimento[]
  criadoEm               DateTime                @default(now())
}

model Transacao {
  id          Int       @id @default(autoincrement())
  descricao   String
  valor       Float
  tipo        String
  data        DateTime
  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  contaId     Int?
  conta       Conta?    @relation(fields: [contaId], references: [id])
  observacao  String?
  criadoEm    DateTime  @default(now())
}

model Ativo {
  id         Int                     @id @default(autoincrement())
  ticker     String                  @unique
  nome       String
  classe     String                  // "acao", "fii", "etf", "bdr", "renda_fixa", "fundo"
  indexador  String?
  taxa       Float?
  vencimento DateTime?
  corretora  String?
  transacoes TransacaoInvestimento[]
  criadoEm   DateTime                @default(now())
}

model TransacaoInvestimento {
  id         Int      @id @default(autoincrement())
  ativoId    Int
  ativo      Ativo    @relation(fields: [ativoId], references: [id])
  tipo       String   // "compra", "venda", "dividendo", "jscp", "rendimento", "amortizacao"
  quantidade Float    @default(0)
  preco      Float    @default(0)
  valor      Float
  taxas      Float    @default(0)
  data       DateTime
  contaId    Int?
  conta      Conta?   @relation(fields: [contaId], references: [id])
  observacao String?
  criadoEm   DateTime @default(now())
}

model Orcamento {
  id          Int       @id @default(autoincrement())
  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  mes         Int
  ano         Int
  limite      Float
  criadoEm    DateTime  @default(now())

  @@unique([categoriaId, mes, ano])
}
